{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",

    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "target": "ES2021",
    "sourceMap": true,

    "outDir": "./dist",
    "rootDir": "./src",

    "baseUrl": "../../",

    "incremental": true,
    "types": ["node", "jest"]
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "**/*.spec.ts"]
}