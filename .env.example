# Shared
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL
POSTGRES_USER=zippy
POSTGRES_PASSWORD=zippy123
POSTGRES_DB=zippy

# Prisma DATABASE_URL per service (multi-schema over same Postgres DB)
DATABASE_URL_AUTH=postgresql://zippy:zippy123@postgres:5432/zippy?schema=auth
DATABASE_URL_RIDE=postgresql://zippy:zippy123@postgres:5432/zippy?schema=ride
DATABASE_URL_DRIVER=postgresql://zippy:zippy123@postgres:5432/zippy?schema=driver
DATABASE_URL_PAYMENT=postgresql://zippy:zippy123@postgres:5432/zippy?schema=payment

# Redis
REDIS_URL=redis://redis:6379
DRIVER_PRESENCE_FRESHNESS_SECONDS=60
OUTBOX_LEASE_SECONDS=60
OUTBOX_BATCH_SIZE=50
MAX_STREAM_RETRIES=5

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=zippy-private

# Cloudflare / Traefik
CF_DNS_API_TOKEN=replace_me
ACME_EMAIL=ops@zippy.com.ar
TRAEFIK_DOMAIN=zippy.local

# Service ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
RIDE_SERVICE_PORT=3002
DRIVER_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3004
ADMIN_PANEL_PORT=3005

# Auth
JWT_ACCESS_SECRET=replace_with_at_least_32_chars_long_secret
JWT_ACCESS_EXPIRES_IN=15m
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_EXPIRES_DAYS=30
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_MIN=10

# Gateway security
CORS_ORIGINS=http://localhost:3000,http://localhost:3005
CORS_CREDENTIALS=true
WS_CORS_ORIGINS=http://localhost:3000,http://localhost:3005
TRUST_PROXY=1
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
THROTTLE_AUTH_TTL_MS=60000
THROTTLE_AUTH_LIMIT=10
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT_GENERAL=100
THROTTLE_LIMIT_AUTH=10
PROXY_TIMEOUT_MS=15000
PROXY_CONNECT_TIMEOUT_MS=5000

API_GATEWAY_INTERNAL_URL=http://api-gateway:3000
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:3000

# Local auth bootstrap seed (used by auth prisma seed)
ZIPPY_ADMIN_EMAIL=admin@zippy.local
ZIPPY_ADMIN_PASSWORD=ChangeMe_12345!
ZIPPY_ADMIN_STATUS=ACTIVE
ZIPPY_ADMIN_RESET_PASSWORD=0

# Local auth container behavior
RUN_DB_MIGRATIONS=1
RUN_DB_SEED=0

# Observability
METRICS_ENABLED=0
